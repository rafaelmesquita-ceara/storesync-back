<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StoreSyncFront.App"
             xmlns:local="using:StoreSyncFront"
             xmlns:controls="using:StoreSyncFront.Controls" 
             xmlns:themes="clr-namespace:Material.Styles.Themes;assembly=Material.Styles"
             xmlns:controls1="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>


    <Application.Styles>
        <!-- O FluentTheme é necessário para fornecer recursos base para controles como o DataGrid -->
        <FluentTheme />
        <themes:MaterialTheme BaseTheme="Dark" PrimaryColor="Amber" SecondaryColor="DeepOrange" />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <avalonia:MaterialIconStyles />
    </Application.Styles>
    
    <Application.Resources>
        <ControlTheme x:Key="{x:Type controls:GenericFormControl}" TargetType="controls:GenericFormControl">
            <Setter Property="Template">
                <ControlTemplate>
                    <controls1:Card Margin="16">
                        <Grid RowDefinitions="Auto, Auto, *" Margin="16">
                            <!-- O TemplateBinding conecta a propriedade do controle (Header) com a propriedade do template (Text) -->
                            <TextBlock Grid.Row="0" Text="{TemplateBinding Header}" Classes="Headline6" Margin="0,0,0,10"/>
             
                            <Separator Grid.Row="1" Margin="0,0,0,10"/>
             
                            <!-- O ContentPresenter exibe o que for colocado dentro das tags do nosso controle -->
                            <ContentPresenter Grid.Row="2" Content="{TemplateBinding Content}"/>
                        </Grid>
                    </controls1:Card>
                </ControlTemplate>
            </Setter>
        </ControlTheme>
    </Application.Resources>
</Application>
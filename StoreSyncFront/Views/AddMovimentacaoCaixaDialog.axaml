<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
    xmlns:p1="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
    x:Class="StoreSyncFront.Views.AddMovimentacaoCaixaDialog"
    Title="Adicionar Movimentação"
    Width="400"
    Height="300"
    CanResize="False"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <controls:Card Margin="16">
        <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">

            <ComboBox
                x:Name="TipoCombo"
                Grid.Row="0"
                HorizontalAlignment="Stretch"
                Margin="0,0,0,12"
                p1:ComboBoxAssist.Label="Tipo"
                Theme="{StaticResource MaterialOutlineComboBox}" />

            <TextBox
                x:Name="DescricaoBox"
                Grid.Row="1"
                Margin="0,0,0,12"
                p1:TextFieldAssist.Label="Descrição"
                UseFloatingWatermark="True" />

            <TextBox
                x:Name="ValorBox"
                Grid.Row="2"
                p1:TextFieldAssist.Label="Valor (R$)"
                UseFloatingWatermark="True"
                KeyDown="ValorBox_KeyDown" />

            <StackPanel
                Grid.Row="4"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    Classes="Outlined"
                    Click="CancelarButton_Click"
                    Width="100">
                    Cancelar
                </Button>
                <Button
                    Classes="Raised"
                    Background="DarkGreen"
                    Click="ConfirmarButton_Click"
                    Width="100">
                    Confirmar
                </Button>
            </StackPanel>

        </Grid>
    </controls:Card>
</Window>

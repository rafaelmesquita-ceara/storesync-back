<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:StoreSyncFront.ViewModels.Dashboard"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:controls1="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="StoreSyncFront.Views.Dashboard.VisaoGeralDashboardView"
             x:DataType="vm:VisaoGeralDashboardViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,8,16,16" Spacing="12">

            <!-- KPI Cards -->
            <UniformGrid Columns="4">
                <controls1:Card Margin="4" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Vendas Finalizadas (Mês)" FontSize="12" Opacity="0.7"/>
                        <TextBlock Text="{Binding TotalVendasMes}" FontSize="30" FontWeight="Bold"/>
                    </StackPanel>
                </controls1:Card>

                <controls1:Card Margin="4" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Faturamento do Mês" FontSize="12" Opacity="0.7"/>
                        <TextBlock Text="{Binding FaturamentoMes, StringFormat='{}{0:C2}'}" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </controls1:Card>

                <controls1:Card Margin="4" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="A Receber em Aberto" FontSize="12" Opacity="0.7"/>
                        <TextBlock Text="{Binding AReceberAberto, StringFormat='{}{0:C2}'}" FontSize="24" FontWeight="Bold" Foreground="#16A34A"/>
                    </StackPanel>
                </controls1:Card>

                <controls1:Card Margin="4" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="A Pagar em Aberto" FontSize="12" Opacity="0.7"/>
                        <TextBlock Text="{Binding APagarAberto, StringFormat='{}{0:C2}'}" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                    </StackPanel>
                </controls1:Card>
            </UniformGrid>

            <!-- Vendas por Dia (Linha) -->
            <controls1:Card Margin="4" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Vendas por Dia — Últimos 30 dias" FontSize="14" FontWeight="SemiBold"/>
                    <lvc:CartesianChart
                        Height="220"
                        Series="{Binding VendasPorDiaSeries}"
                        XAxes="{Binding VendasPorDiaXAxes}"
                        YAxes="{Binding VendasPorDiaYAxes}"
                        LegendPosition="Hidden"/>
                </StackPanel>
            </controls1:Card>

            <!-- Lucro Bruto por Dia (Linha) -->
            <controls1:Card Margin="4" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Lucro Bruto por Dia — Últimos 30 dias" FontSize="14" FontWeight="SemiBold"/>
                    <lvc:CartesianChart
                        Height="220"
                        Series="{Binding LucroBrutoPorDiaSeries}"
                        XAxes="{Binding LucroBrutoPorDiaXAxes}"
                        YAxes="{Binding LucroBrutoPorDiaYAxes}"
                        LegendPosition="Hidden"/>
                </StackPanel>
            </controls1:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
    xmlns:p1="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
    xmlns:materialIcons="using:Material.Icons.Avalonia"
    xmlns:local="clr-namespace:StoreSyncFront.Views"
    x:DataType="local:ExportReportDialogViewModel"
    x:Class="StoreSyncFront.Views.ExportReportDialog"
    Title="Exportar Relatório de Vendas"
    Width="380"
    Height="220"
    CanResize="False"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">

    <controls:Card Margin="16">
        <Grid RowDefinitions="Auto, Auto, Auto">

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,16"
                Classes="Subtitle1"
                Text="Selecione o período para o relatório:" />

            <Grid Grid.Row="1" ColumnDefinitions="*, 16, *" Margin="0,0,0,20">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Classes="Caption" Opacity="0.7" Text="Data inicial" />
                    <CalendarDatePicker
                        x:Name="StartDatePicker"
                        HorizontalAlignment="Stretch"
                        SelectedDate="{Binding StartDate}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Classes="Caption" Opacity="0.7" Text="Data final" />
                    <CalendarDatePicker
                        x:Name="EndDatePicker"
                        HorizontalAlignment="Stretch"
                        SelectedDate="{Binding EndDate}" />
                </StackPanel>
            </Grid>

            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button Classes="Flat" Click="CancelButton_Click">
                    Cancelar
                </Button>
                <Button Classes="Raised" Click="GenerateButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <materialIcons:MaterialIcon Width="16" Height="16" Kind="FilePdfBox" />
                        <TextBlock Text="Gerar PDF" />
                    </StackPanel>
                </Button>
            </StackPanel>

        </Grid>
    </controls:Card>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:StoreSyncFront.ViewModels"
             xmlns:dashVm="clr-namespace:StoreSyncFront.ViewModels.Dashboard"
             xmlns:controls1="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             xmlns:materialIcons="using:Material.Icons.Avalonia"
             xmlns:local="using:StoreSyncFront.Utils"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="900"
             x:Class="StoreSyncFront.Views.HomeView"
             x:DataType="vm:HomeViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Loading overlay -->
        <Panel IsVisible="{Binding IsLoading}" ZIndex="100" Grid.RowSpan="3">
            <Rectangle Fill="#AA000000"/>
            <ProgressBar IsIndeterminate="True" Width="200"
                         VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Panel>

        <!-- Barra superior: Boas-vindas + Refresh -->
        <DockPanel Grid.Row="0" Margin="16,12,16,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Spacing="16">
                <TextBlock Text="{Binding Username, StringFormat='Bem-vindo(a), {0}!'}"
                           FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Command="{Binding ReloadCommand}" ToolTip.Tip="Recarregar Dashboard (F5)"
                        HotKey="F5" Classes="Outline" Padding="6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <materialIcons:MaterialIcon Width="20" Height="20" Kind="Refresh"/>
                        <TextBlock Text="Recarregar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <Panel/> <!-- spacer -->
        </DockPanel>

        <!-- Barra de navegação do carrossel -->
        <Border Grid.Row="1" Margin="16,12,16,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Seta esquerda -->
                <Button Grid.Column="0" Command="{Binding PreviousPageCommand}"
                        Classes="Flat" Padding="8" VerticalAlignment="Center"
                        ToolTip.Tip="Dashboard anterior">
                    <materialIcons:MaterialIcon Width="24" Height="24" Kind="ChevronLeft"/>
                </Button>

                <!-- Botões dos dashboards -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="4">
                    <RadioButton GroupName="DashboardNav"
                                 IsChecked="{Binding CurrentPageIndex, Converter={x:Static local:IndexToBoolConverter.Instance}, ConverterParameter=0}"
                                 Command="{Binding GoToPageCommand}" CommandParameter="0"
                                 Classes="Flat" Padding="16,10" Content="Visão Geral"/>
                    <RadioButton GroupName="DashboardNav"
                                 IsChecked="{Binding CurrentPageIndex, Converter={x:Static local:IndexToBoolConverter.Instance}, ConverterParameter=1}"
                                 Command="{Binding GoToPageCommand}" CommandParameter="1"
                                 Classes="Flat" Padding="16,10" Content="Financeiro"/>
                    <RadioButton GroupName="DashboardNav"
                                 IsChecked="{Binding CurrentPageIndex, Converter={x:Static local:IndexToBoolConverter.Instance}, ConverterParameter=2}"
                                 Command="{Binding GoToPageCommand}" CommandParameter="2"
                                 Classes="Flat" Padding="16,10" Content="Vendas"/>
                    <RadioButton GroupName="DashboardNav"
                                 IsChecked="{Binding CurrentPageIndex, Converter={x:Static local:IndexToBoolConverter.Instance}, ConverterParameter=3}"
                                 Command="{Binding GoToPageCommand}" CommandParameter="3"
                                 Classes="Flat" Padding="16,10" Content="Estoque"/>
                </StackPanel>

                <!-- Seta direita -->
                <Button Grid.Column="2" Command="{Binding NextPageCommand}"
                        Classes="Flat" Padding="8" VerticalAlignment="Center"
                        ToolTip.Tip="Próximo dashboard">
                    <materialIcons:MaterialIcon Width="24" Height="24" Kind="ChevronRight"/>
                </Button>
            </Grid>
        </Border>

        <!-- Carousel com as páginas de dashboard -->
        <Carousel Grid.Row="2"
                   ItemsSource="{Binding DashboardPages}"
                   SelectedIndex="{Binding CurrentPageIndex}">
            <Carousel.PageTransition>
                <PageSlide Duration="0:0:0.2" Orientation="Horizontal"/>
            </Carousel.PageTransition>
        </Carousel>

    </Grid>
</UserControl>

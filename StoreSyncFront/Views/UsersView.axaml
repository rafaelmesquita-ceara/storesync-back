<UserControl
    x:Class="StoreSyncFront.Views.UsersView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls1="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
    xmlns:converters="using:StoreSyncFront.Utils"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialIcons="using:Material.Icons.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:p1="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
    xmlns:shared="using:SharedModels"
    xmlns:vm="clr-namespace:StoreSyncFront.ViewModels"
    x:Name="Root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:UsersViewModel"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </UserControl.Resources>

    <controls1:Card Margin="16">
        <Grid Margin="16" RowDefinitions="Auto, Auto, *, Auto">

            <!--  Header: título + busca  -->
            <Grid
                Margin="0,0,0,10"
                HorizontalAlignment="Stretch"
                ColumnDefinitions="*, *">
                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Classes="Headline6"
                    Text="Usuários" />

                <TextBox
                    x:Name="SearchTextBox"
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    Classes="solo"
                    KeyUp="SearchTextBox_KeyUp"
                    Loaded="SearchTextBox_Loaded"
                    Text="{Binding SearchBarField}"
                    Theme="{StaticResource SoloTextBox}"
                    Watermark="Buscar usuário...">
                    <TextBox.InnerRightContent>
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="5">
                            <Button
                                Width="{Binding $self.Bounds.Height}"
                                Padding="4"
                                Classes="Flat"
                                Command="{Binding SearchCommand}">
                                <materialIcons:MaterialIcon
                                    Width="24"
                                    Height="24"
                                    Kind="Search" />
                            </Button>
                            <Button
                                Width="{Binding $self.Bounds.Height}"
                                Padding="4"
                                Classes="Flat"
                                HotKey="F5"
                                Command="{Binding RefreshCommand}">
                                <materialIcons:MaterialIcon
                                    Width="24"
                                    Height="24"
                                    Kind="Refresh" />
                            </Button>
                        </StackPanel>
                    </TextBox.InnerRightContent>
                </TextBox>
            </Grid>

            <Separator Grid.Row="1" Margin="0,0,0,10" />

            <!--  DataGrid sempre visível — Login com edição inline  -->
            <Grid Grid.Row="2" RowDefinitions="*, Auto">
                <DataGrid Grid.Row="0"
                    x:Name="UsersDataGrid"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding Users}"
                    KeyDown="UsersDataGrid_KeyDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="4*"
                            Binding="{Binding Employee.Name}"
                            Header="Funcionário" />
                        <DataGridTextColumn
                            Width="2*"
                            Binding="{Binding Employee.Role}"
                            Header="Cargo" />

                        <!--  Coluna Login: TextBlock (leitura) ou TextBox (edição inline)  -->
                        <DataGridTemplateColumn Width="3*" Header="Login">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="vm:UserRowViewModel">
                                    <Panel>
                                        <TextBlock
                                            IsVisible="{Binding IsEditing, Converter={StaticResource InverseBooleanConverter}}"
                                            Text="{Binding Login}"
                                            VerticalAlignment="Center"
                                            Margin="4,0" />
                                        <TextBox
                                            IsVisible="{Binding IsEditing}"
                                            Text="{Binding DraftLogin}"
                                            KeyDown="InlineLoginBox_KeyDown"
                                            LostFocus="InlineLoginBox_LostFocus"
                                            UseFloatingWatermark="False" />
                                    </Panel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Ações">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="vm:UserRowViewModel">
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="5">
                                        <controls1:FloatingButton
                                            Margin="3"
                                            Classes="Mini"
                                            Click="LoginEditButton_Click"
                                            Tag="{Binding UserId}"
                                            ToolTip.Tip="Editar login (F2)">
                                            <materialIcons:MaterialIcon
                                                Width="16"
                                                Height="16"
                                                Kind="Edit" />
                                        </controls1:FloatingButton>
                                        <controls1:FloatingButton
                                            Margin="3"
                                            Classes="Mini"
                                            Click="ChangePasswordButton_Click"
                                            Tag="{Binding UserId}"
                                            ToolTip.Tip="Alterar senha">
                                            <materialIcons:MaterialIcon
                                                Width="16"
                                                Height="16"
                                                Kind="Key" />
                                        </controls1:FloatingButton>
                                        <controls1:FloatingButton
                                            Margin="3,3,15,3"
                                            Background="Red"
                                            Classes="Mini"
                                            Command="{Binding #Root.((vm:UsersViewModel)DataContext).DeleteCommand}"
                                            CommandParameter="{Binding UserId}">
                                            <materialIcons:MaterialIcon
                                                Width="16"
                                                Height="16"
                                                Kind="Delete" />
                                        </controls1:FloatingButton>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!--  FAB +: abre painel de criação  -->
                <controls1:FloatingButton
                    Grid.Row="0" Grid.RowSpan="2"
                    Margin="24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="DarkGreen"
                    Command="{Binding ToggleEditCommand}"
                    HotKey="F1"
                    IsVisible="{Binding IsEdit, Converter={StaticResource InverseBooleanConverter}}">
                    <materialIcons:MaterialIcon Kind="Plus" />
                </controls1:FloatingButton>

                <!-- Paginação -->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,10,0,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal"
                    IsVisible="{Binding IsEdit, Converter={StaticResource InverseBooleanConverter}}"
                    Spacing="10">
                    <Button Classes="Flat" Command="{Binding PreviousPageCommand}">
                        <materialIcons:MaterialIcon Kind="ChevronLeft" />
                    </Button>
                    <TextBlock VerticalAlignment="Center" Text="{Binding CurrentPage, StringFormat='Página {0}'}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding TotalPages, StringFormat='de {0}'}" />
                    <Button Classes="Flat" Command="{Binding NextPageCommand}">
                        <materialIcons:MaterialIcon Kind="ChevronRight" />
                    </Button>
                </StackPanel>
            </Grid>

            <!--  Painel de criação de novo usuário (só aparece quando IsEdit = true)  -->
            <Grid
                Grid.Row="3"
                IsVisible="{Binding IsEdit}"
                Margin="0,12,0,0">
                <Grid RowDefinitions="Auto, Auto">
                    <StackPanel Grid.Row="0" Spacing="8">
                        <ComboBox
                            p1:ComboBoxAssist.Label="Funcionário"
                            ItemsSource="{Binding AvailableEmployees}"
                            SelectedItem="{Binding SelectedEmployee}"
                            Theme="{StaticResource MaterialOutlineComboBox}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate DataType="shared:Employee">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBox
                            p1:TextFieldAssist.Hints="{Binding (DataValidationErrors.Errors)}"
                            p1:TextFieldAssist.Label="Login"
                            Text="{Binding Login}"
                            UseFloatingWatermark="True" />

                        <TextBox
                            PasswordChar="•"
                            p1:TextFieldAssist.Label="Senha"
                            Text="{Binding Password}"
                            UseFloatingWatermark="True" />

                        <TextBox
                            PasswordChar="•"
                            p1:TextFieldAssist.Label="Confirmar senha"
                            Text="{Binding ConfirmPassword}"
                            UseFloatingWatermark="True" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="8">
                        <controls1:FloatingButton
                            Background="DarkRed"
                            Command="{Binding ClearFormCommand}"
                            HotKey="Escape">
                            <materialIcons:MaterialIcon Kind="Close" />
                        </controls1:FloatingButton>
                        <controls1:FloatingButton
                            Background="DarkGreen"
                            Command="{Binding AddUserCommand}"
                            HotKey="Enter">
                            <materialIcons:MaterialIcon Kind="Check" />
                        </controls1:FloatingButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </controls1:Card>
</UserControl>
